# ============================================================
# Voice AI Agent — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── STT Backend ──────────────────────────────────────────
# Options: whisper_local | groq
STT_BACKEND=whisper_local

# Whisper model size (tiny | base | small | medium | large)
# "base" is a good balance of speed and accuracy
WHISPER_MODEL_SIZE=base

# ── LLM Backend ──────────────────────────────────────────
# Options: ollama | groq
LLM_BACKEND=ollama

# Ollama settings (only needed if LLM_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=tinyllama

# ── API Keys (only needed for cloud backends) ─────────────
# Get a free Groq key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Groq model for LLM (when LLM_BACKEND=groq)
GROQ_MODEL=llama3-8b-8192

# ── TTS ───────────────────────────────────────────────────
# Enable voice feedback
TTS_ENABLED=true
# Options: pyttsx3 (offline) | gtts (online, better quality)
TTS_ENGINE=pyttsx3

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
